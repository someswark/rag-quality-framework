{
  "framework": {
    "name": "Enterprise AI Quality Framework",
    "version": "2.1"
  },

 "execution": {
    "mode": "mock",
    "profile": "demo"

  },

  "application": {
    "name": "Enterprise AI Copilot",
    "type": "RAG Chatbot",
    "description": "Internal enterprise knowledge assistant"
  },

	"knowledge_source": {
		"enabled": false
	},

  "llm": {

    "provider": "Gemini",

    "model": "gemini-2.5-flash",

    "api_key": ""

  },

  "evaluation": {

    "dataset": "golden_dataset.csv",

    "metrics": [

      "accuracy",

      "grounding",

      "completeness",

      "safety",

      "hallucination"

    ]

  },

  "answer_provider": {

    "provider": "mock"

  },

  "output": {

    "summary_json": "../website/assets/data/summary.json",

    "reports_folder": "../website/assets/reports"

  }

}